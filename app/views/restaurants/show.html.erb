<div class="container">
  <h1><%= @restaurant.name %></h1>
  <h2><%= @restaurant.address %></h2>
  <h3><%= @restaurant.category %></h3>
  <%= link_to "Nouvel avis", new_restaurant_review_path(@restaurant) %> | <%= link_to "Back", restaurants_path %>
  <hr>
  <p><strong>Reviews</strong></p>
  <ul class="list-group">
    <% @restaurant.reviews.each do |review| %>
      <li class="list-group-item">Note: <%= review.rating %><br><%= review.content %></li>
    <% end %>
  </ul>
</div>
