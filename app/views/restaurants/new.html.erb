<div class="container">
  <%= simple_form_for(@restaurant) do |f| %>
    <div class="form-inputs">
      <%= f.input :name %>
      <%= f.input :address %>
      <%= f.input :category %>
    </div>
    <div class="form-actions">
      <%= f.submit %>
    </div>
  <% end %>
  <%= link_to "Back", restaurants_path %>
</div>
