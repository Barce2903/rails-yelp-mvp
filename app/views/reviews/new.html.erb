<div class="container">
  <h1>Nouvel avis</h1>
  <%= simple_form_for [@restaurant, @review] do |f| %>
    <div class="form-inputs">
      <%= f.input :content %>
      <%= f.input :rating %>
    </div>
    <div class="form-actions">
      <%= f.submit "Créer", class: "btn btn-primary" %>
    </div>
  <% end %>
  <%= link_to "Back", restaurant_path(@restaurant) %>
</div>
